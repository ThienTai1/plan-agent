# Global
APP_ENV=development
LOG_LEVEL=DEBUG
TIMEZONE=UTC

# Gateway Service
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_ALLOWED_ORIGINS=*
AGENT_SERVICE_URL=http://agent-service:8100
AUTH_SERVICE_URL=http://auth-service:8200
CALENDAR_SERVICE_URL=http://calendar-service:8300

# Agent Service
AGENT_SERVICE_HOST=0.0.0.0
AGENT_SERVICE_PORT=8100
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=changeme
BOUNDARY_PROJECT_ID=
BOUNDARY_SECRET=
BAML_STAGE=prod
BAML_PLANNER_NAME=PlanningAgent

# Calendar Service
CALENDAR_SERVICE_HOST=0.0.0.0
CALENDAR_SERVICE_PORT=8300
CALENDAR_DEFAULT_PROVIDER=google
REDIS_CACHE_TTL_SECONDS=120
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=calendar.events

# Auth Service
AUTH_SERVICE_HOST=0.0.0.0
AUTH_SERVICE_PORT=8200
AUTH_JWT_SECRET=super-secret
AUTH_JWT_TTL_MINUTES=60

# Shared
DATABASE_URL=postgresql+psycopg2://agent:agent@postgres/agent
REDIS_URL=redis://redis:6379/0
