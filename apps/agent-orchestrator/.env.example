# Planning Agent Backend - Environment Configuration

# ════════════════════════════════════════════════════════════════
# OPENROUTER LLM CONFIGURATION
# ════════════════════════════════════════════════════════════════

# Required: Get from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Specify which model to use
# Options: qwen/qwen-plus, qwen/qwen-turbo, openai/gpt-4, meta-llama/llama-2-7b, etc.
LLM_MODEL=openrouter:qwen/qwen-plus

# Optional: Fallback API key (if not using OPENROUTER_API_KEY)
LLM_API_KEY=your-api-key-here

# ════════════════════════════════════════════════════════════════
# LLM PARAMETERS
# ════════════════════════════════════════════════════════════════

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_PROVIDER=openrouter

# ════════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION
# ════════════════════════════════════════════════════════════════

# URL where frontend is running (for tool execution)
FRONTEND_URL=http://localhost:3000
FRONTEND_API_URL=http://localhost:3000/api

# ════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (OPTIONAL)
# ════════════════════════════════════════════════════════════════

# Supabase (optional, for backend data access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ════════════════════════════════════════════════════════════════

DEBUG=True
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Session timeout in seconds (30 minutes)
SESSION_TIMEOUT=1800

# JWT Secret for authentication
JWT_SECRET=your-secret-key-change-in-production

# ════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ════════════════════════════════════════════════════════════════

ENABLE_WEB_SEARCH=True
ENABLE_DATABASE_TOOLS=True
