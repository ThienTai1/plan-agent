# BAML Service Environment Variables Configuration Template

# Gemini API Key (Required for gemini LLMs)
GEMINI_API_KEY="your_gemini_api_key_here"

# LiteLLM API Key (if using LiteLLM provider)
LITE_LLM_API_KEY="your_lite_llm_api_key_here"

# Supabase Configurations
SUPABASE_URL="https://your_supabase_project.supabase.co"
SUPABASE_KEY="your_supabase_anon_or_service_role_key_here"
SUPABASE_JWT_SECRET="your_supabase_jwt_secret_here"

# OpenAI API Key (if using openai provider)
OPENAI_API_KEY="your_openai_api_key_here"

# OpenRouter API Key (if using openrouter provider)
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Additional configurations
# LLM_BASE_URL="optional_custom_base_url"
# LLM_MODEL_NAME="optional_custom_model_name"
